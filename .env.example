NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: Stripe webhooks, post-signup Resend emails (verify user before sending), etc. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Transactional email (Resend). Without RESEND_API_KEY, sends are no-ops in dev.
RESEND_API_KEY=
# Optional; default from address (must be verified in Resend)
RESEND_FROM_EMAIL=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: for AI listing description generation (GPT-3.5)
OPENAI_API_KEY=
